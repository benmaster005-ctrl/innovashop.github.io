<!DOCTYPE html>
<html lang="fr" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Commande #{{ commande.id }}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&display=swap');
    * { font-family: 'IBM Plex Mono', monospace; }
  </style>
</head>
<body class="bg-zinc-100 py-10 px-4">

  <table width="100%" cellpadding="0" cellspacing="0" role="presentation" class="max-w-[560px] mx-auto">
  <tr><td>

    {# ── EN-TÊTE ── #}
    <table width="100%" cellpadding="0" cellspacing="0" role="presentation" class="bg-zinc-900">
      <tr>
        <td class="px-8 py-7">
          <p class="text-[10px] tracking-[0.3em] uppercase text-zinc-500 mb-1">Récapitulatif</p>
          <p class="text-white text-base font-medium">Commande <span class="text-zinc-400">#{{ commande.id }}</span></p>
          <p class="text-zinc-500 text-[11px] mt-1">{{ commande.date|date('d/m/Y à H:i') }}</p>
        </td>
      </tr>
    </table>

    {# ── CORPS ── #}
    <table width="100%" cellpadding="0" cellspacing="0" role="presentation" class="bg-white">
      <tr>
        <td class="px-8 py-8">

          {# Intro #}
          <p class="text-xs text-zinc-500 leading-6 mb-7">
            Bonjour <strong class="text-zinc-900 font-medium">{{ commande.utilisateur.email }}</strong>,<br>
            votre commande a bien été enregistrée.
          </p>

          {# ── STATUT ── #}
          {% set statuts = {
            'en_attente': { label: 'En attente', color: 'text-amber-600',   bg: 'bg-amber-50',   dot: 'bg-amber-400'   },
            'confirmee':  { label: 'Confirmée',  color: 'text-emerald-700', bg: 'bg-emerald-50', dot: 'bg-emerald-500' },
            'expediee':   { label: 'Expédiée',   color: 'text-blue-700',    bg: 'bg-blue-50',    dot: 'bg-blue-500'    },
            'livree':     { label: 'Livrée',     color: 'text-emerald-700', bg: 'bg-emerald-50', dot: 'bg-emerald-500' },
            'annulee':    { label: 'Annulée',    color: 'text-red-700',     bg: 'bg-red-50',     dot: 'bg-red-500'     }
          } %}
          {% set s = statuts[commande.status] ?? { label: commande.status, color: 'text-zinc-600', bg: 'bg-zinc-50', dot: 'bg-zinc-400' } %}

          <div class="inline-flex items-center gap-2 {{ s.bg }} px-3 py-1.5 mb-8">
            <span class="w-1.5 h-1.5 rounded-full {{ s.dot }}"></span>
            <span class="text-[10px] tracking-[0.15em] uppercase {{ s.color }}">{{ s.label }}</span>
          </div>

          {# ── PRODUIT ── #}
          <p class="text-[10px] tracking-[0.25em] uppercase text-zinc-400 mb-2">Produit commandé</p>
          <table width="100%" cellpadding="0" cellspacing="0" role="presentation"
                 class="border-t border-b border-zinc-100 mb-7">
            <tr>
              <td class="py-4 text-xs text-zinc-900 font-medium">
                {{ commande.produit.nom }}
              </td>
              <td class="py-4 text-right text-xs font-medium text-zinc-900 whitespace-nowrap">
                {{ commande.total }} €
              </td>
            </tr>
          </table>

          {# ── TOTAL ── #}
          <table width="100%" cellpadding="0" cellspacing="0" role="presentation" class="mb-8">
            <tr>
              <td class="py-3 border-t-2 border-zinc-900 text-sm font-medium text-zinc-900">Total</td>
              <td class="py-3 border-t-2 border-zinc-900 text-right text-sm font-medium text-zinc-900">
                {{ commande.total }} €
              </td>
            </tr>
          </table>

          {# ── DÉTAILS ── #}
          <p class="text-[10px] tracking-[0.25em] uppercase text-zinc-400 mb-2">Détails</p>
          <table width="100%" cellpadding="0" cellspacing="0" role="presentation"
                 class="text-[11px] mb-9">
            <tr class="border-b border-zinc-50">
              <td class="py-2 text-zinc-400 w-1/3">Référence</td>
              <td class="py-2 text-zinc-800">#{{ commande.id }}</td>
            </tr>
            <tr class="border-b border-zinc-50">
              <td class="py-2 text-zinc-400">Client</td>
              <td class="py-2 text-zinc-800">{{ commande.utilisateur.email }}</td>
            </tr>
            <tr>
              <td class="py-2 text-zinc-400">Date</td>
              <td class="py-2 text-zinc-800">{{ commande.date|date('d/m/Y à H:i') }}</td>
            </tr>
          </table>

          {# ── CTA ── #}
          {% if orderUrl is defined and orderUrl %}
          <a href="{{ orderUrl }}"
             class="inline-block bg-zinc-900 text-white text-[10px] tracking-[0.2em] uppercase px-6 py-3 no-underline">
            Voir la commande →
          </a>
          {% endif %}

        </td>
      </tr>
    </table>

    {# ── PIED ── #}
    <table width="100%" cellpadding="0" cellspacing="0" role="presentation"
           class="border-t border-zinc-200 bg-zinc-50">
      <tr>
        <td class="px-8 py-4 text-center">
          <p class="text-[10px] text-zinc-400 tracking-wide">
            © {{ "now"|date("Y") }} {{ shopName ?? 'Ma Boutique' }}
          </p>
        </td>
      </tr>
    </table>

  </td></tr>
  </table>

</body>
</html>
